___TESTS___

scenarios:
- name: configuration was added correctly
  code: |-
    const mockData = {
      siteId: '68ba9493363e8e93f7a53837',
      publicKey: '14kVRgOQYi304CGbg6ADTA',
      lang: 'en',
      style: 'neutral'
    };

    mock('setInWindow', function(key, value) {
      if (key !== '__alttextlab_config') {
        fail('setInWindow called with unexpected key: ' + key);
      }
      if (value.siteId !== mockData.siteId) {
        fail('siteId mismatch');
      }
      if (value.publicKey !== mockData.publicKey) {
        fail('publicKey mismatch');
      }
      if (value.lang !== mockData.lang) {
        fail('lang mismatch');
      }
      if (value.style !== mockData.style) {
        fail('style mismatch');
      }
    });

    mock('injectScript', function(url, onSuccess, onFailure) {
      if (url !== 'https://cdn.alttextlab.com/embed.js?config=global') {
        fail('injectScript called with unexpected URL: ' + url);
      }
      onSuccess();
    });

    runCode(mockData);

    assertApi('gtmOnSuccess').wasCalled();


